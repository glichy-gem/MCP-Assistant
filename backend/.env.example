# Copy to `.env`. The MCP server creds are read from the PARENT folder's .env
# (ServiceNow MCP/.env: MCP_ENDPOINT / MCP_API_KEY) - no need to repeat them here.

# --- Groq (OpenAI-compatible, fast free tier) ---
# Free key at https://console.groq.com
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# DEPRECATED: superseded by DB-backed RBAC (per-user tool grants in Postgres).
# Left for reference only; it is no longer the tool gate.
ENABLED_TOOLS=

# --- PostgreSQL (RBAC store: users, tools catalog, per-user grants, role defaults) ---
# The app creates its tables on first boot (CREATE TABLE IF NOT EXISTS) and seeds a
# super_admin from ADMIN_USER/ADMIN_PASSWORD when the users table is empty.
POSTGRES_HOST=your-postgres-host
POSTGRES_PORT=5432
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=your_database_name
POSTGRES_SSLMODE=require

# --- Authentication ---
# First-run seed for the local super_admin account. If the Postgres users table is
# empty, the backend seeds one super_admin user from these values. If ADMIN_PASSWORD
# is missing on a fresh install, the backend refuses to start (so it can never come
# up open to anyone).
ADMIN_USER=admin
ADMIN_PASSWORD=change-me-on-first-run

# Signed session cookie secret. If empty, one is auto-generated on first run and
# written to backend/.session_secret (git-ignored). Set explicitly in production.
SESSION_SECRET=

# --- Google (OIDC single sign-on). Leave blank to keep local login only. ---
# Create an OAuth client ID in Google Cloud Console (APIs & Services > Credentials
# > Create Credentials > OAuth client ID > Web application); copy its values here.
#   GOOGLE_ISSUER        fixed: https://accounts.google.com
#   GOOGLE_REDIRECT_URI  MUST exactly match an "Authorized redirect URI" on that
#                        OAuth client, including the port your backend serves on.
# New Google users are auto-provisioned (JIT) as role 'user'; a super_admin can promote
# them. Existing local accounts are linked to Google by matching email.
GOOGLE_ISSUER=https://accounts.google.com
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8001/api/auth/google/callback
GOOGLE_SCOPES=openid profile email
GOOGLE_POST_LOGIN_REDIRECT=/

