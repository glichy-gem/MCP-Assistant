# Copy this file to `.env` and fill in the values. `.env` is git-ignored.

# Endpoint of the ServiceNow MCP server.
# Azure portal -> Logic App -> MCP servers -> your server -> Copy URL
MCP_ENDPOINT=https://logicapp-019951.azurewebsites.net/api/mcpservers/ServiceNowMCPserver/mcp

# API key for the Logic App MCP server.
# Azure portal -> Logic App -> MCP servers -> Authentication -> Method: Key-based -> Generate key.
# Regenerate a fresh key so you are NOT reusing the previously exposed one.
MCP_API_KEY=paste-your-regenerated-key-here

# HTTP header the server expects the key in.
# For Azure Logic Apps MCP servers this is X-API-Key (leave as-is unless yours differs).
MCP_AUTH_HEADER=X-API-Key
